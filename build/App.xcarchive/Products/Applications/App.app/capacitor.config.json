{
	"appId": "com.idoneo.app",
	"appName": "Idoneo",
	"webDir": "dist",
	"server": {
		"iosScheme": "https"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#00B1FF",
			"showSpinner": false,
			"iosSpinnerStyle": "small",
			"spinnerColor": "#ffffff",
			"splashFullScreen": true,
			"splashImmersive": true
		},
		"StatusBar": {
			"style": "DARK",
			"overlaysWebView": true
		},
		"Keyboard": {
			"resize": "body",
			"resizeOnFullScreen": true
		},
		"CapacitorHttp": {
			"enabled": true
		}
	},
	"ios": {
		"contentInset": "never",
		"preferredContentMode": "mobile",
		"allowsLinkPreview": false,
		"scheme": "idoneo",
		"backgroundColor": "#FFFFFF"
	},
	"packageClassList": [
		"AppPlugin",
		"CAPBrowserPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"CAPNetworkPlugin",
		"PreferencesPlugin",
		"SharePlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin",
		"SecureStoragePlugin"
	]
}
